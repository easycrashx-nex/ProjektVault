{
  "name": "arcane-vault",
  "version": "0.1.0",
  "private": true,
  "description": "Projekt Vault with local browser mode and a server-ready backend scaffold.",
  "scripts": {
    "sync:frontend": "node scripts/sync-frontend.mjs",
    "dev": "node scripts/sync-frontend.mjs && node backend/src/server.js",
    "start": "node backend/src/server.js",
    "start:sync": "node scripts/sync-frontend.mjs && node backend/src/server.js",
    "check": "node --check app.js && node --check backend/src/server.js"
  },
  "engines": {
    "node": ">=20"
  }
}
